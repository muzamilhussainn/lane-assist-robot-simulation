<?xml version="1.0" ?>
<sdf version="1.6">
  <model name="ackermann_car">
    <static>false</static>

    <!-- ===================== -->
    <!-- Base / chassis         -->
    <!-- ===================== -->
    <link name="base_link">
      <pose>0 0 0.15 0 0 0</pose>

      <inertial>
        <mass>5.0</mass>
        <inertia>
          <ixx>0.2</ixx><iyy>0.2</iyy><izz>0.2</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>

      <collision name="base_collision">
        <geometry><box><size>0.6 0.35 0.15</size></box></geometry>
      </collision>

      <visual name="base_visual">
        <geometry><box><size>0.6 0.35 0.15</size></box></geometry>
      </visual>
    </link>

    <!-- Parameters (geometry) -->
    <!-- wheelBase: distance between front and rear axles -->
    <!-- trackWidth: distance between left and right wheels -->
    <!-- wheelRadius: wheel radius -->
    <!-- wheelWidth: wheel thickness -->
    <!-- positions below match these roughly -->
    <!-- =============================================== -->

    <!-- ===================== -->
    <!-- Rear wheels (drive)    -->
    <!-- ===================== -->
    <link name="wheel_rl">
      <pose>-0.2  0.17 0.08 0 1.5708 0</pose>
      <collision name="collision">
        <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
        <surface>
          <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
        </surface>
      </collision>
      <visual name="visual">
        <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
      </visual>
    </link>

    <link name="wheel_rr">
      <pose>-0.2 -0.17 0.08 0 1.5708 0</pose>
      <collision name="collision">
        <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
        <surface>
          <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
        </surface>
      </collision>
      <visual name="visual">
        <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
      </visual>
    </link>

    <!-- ===================== -->
    <!-- Front steering knuckles -->
    <!-- ===================== -->
    <link name="steer_fl">
      <pose>0.25  0.17 0.08 0 0 0</pose>
      <inertial><mass>0.1</mass></inertial>
      <visual name="visual">
        <geometry><box><size>0.02 0.02 0.02</size></box></geometry>
      </visual>
    </link>

    <link name="steer_fr">
      <pose>0.25 -0.17 0.08 0 0 0</pose>
      <inertial><mass>0.1</mass></inertial>
      <visual name="visual">
        <geometry><box><size>0.02 0.02 0.02</size></box></geometry>
      </visual>
    </link>

    <!-- Front wheels (spin) -->
    <link name="wheel_fl">
      <pose>0.25  0.17 0.08 0 1.5708 0</pose>
      <collision name="collision">
        <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
        <surface>
          <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
        </surface>
      </collision>
      <visual name="visual">
        <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
      </visual>
    </link>

    <link name="wheel_fr">
      <pose>0.25 -0.17 0.08 0 1.5708 0</pose>
      <collision name="collision">
        <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
        <surface>
          <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
        </surface>
      </collision>
      <visual name="visual">
        <geometry><cylinder><radius>0.06</radius><length>0.04</length></cylinder></geometry>
      </visual>
    </link>

    <!-- ===================== -->
    <!-- Joints                 -->
    <!-- ===================== -->

    <!-- Rear wheel spin joints -->
    <joint name="joint_rl_wheel" type="revolute">
      <parent>base_link</parent>
      <child>wheel_rl</child>
      <axis>
        <xyz>0 1 0</xyz>
        <dynamics><damping>0.5</damping><friction>0.2</friction></dynamics>
      </axis>
    </joint>

    <joint name="joint_rr_wheel" type="revolute">
      <parent>base_link</parent>
      <child>wheel_rr</child>
      <axis>
        <xyz>0 1 0</xyz>
        <dynamics><damping>0.5</damping><friction>0.2</friction></dynamics>
      </axis>
    </joint>

    <!-- Front steering joints (turn about Z) -->
    <joint name="joint_fl_steer" type="revolute">
      <parent>base_link</parent>
      <child>steer_fl</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-0.6</lower>
          <upper>0.6</upper>
        </limit>
        <dynamics><damping>0.8</damping><friction>0.2</friction></dynamics>
      </axis>
    </joint>

    <joint name="joint_fr_steer" type="revolute">
      <parent>base_link</parent>
      <child>steer_fr</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-0.6</lower>
          <upper>0.6</upper>
        </limit>
        <dynamics><damping>0.8</damping><friction>0.2</friction></dynamics>
      </axis>
    </joint>

    <!-- Front wheel spin joints (spin about Y) -->
    <joint name="joint_fl_wheel" type="revolute">
      <parent>steer_fl</parent>
      <child>wheel_fl</child>
      <axis>
        <xyz>0 1 0</xyz>
        <dynamics><damping>0.5</damping><friction>0.2</friction></dynamics>
      </axis>
    </joint>

    <joint name="joint_fr_wheel" type="revolute">
      <parent>steer_fr</parent>
      <child>wheel_fr</child>
      <axis>
        <xyz>0 1 0</xyz>
        <dynamics><damping>0.5</damping><friction>0.2</friction></dynamics>
      </axis>
    </joint>

    <!-- ===================== -->
    <!-- Ackermann drive plugin -->
    <!-- ===================== -->
    <plugin name="ackermann_drive" filename="libgazebo_ros_ackermann_drive.so">
      <robotNamespace>/</robotNamespace>

      <!-- Steering joints -->
      <leftFrontSteeringJoint>joint_fl_steer</leftFrontSteeringJoint>
      <rightFrontSteeringJoint>joint_fr_steer</rightFrontSteeringJoint>

      <!-- Drive wheel joints -->
      <leftRearWheelJoint>joint_rl_wheel</leftRearWheelJoint>
      <rightRearWheelJoint>joint_rr_wheel</rightRearWheelJoint>

      <!-- Geometry -->
      <wheelBase>0.45</wheelBase>
      <wheelSeparation>0.34</wheelSeparation>
      <wheelDiameter>0.12</wheelDiameter>

      <!-- Limits -->
      <steeringLimit>0.6</steeringLimit>

      <!-- ROS topics/frames -->
      <commandTopic>/cmd_vel</commandTopic>
      <odometryTopic>/odom</odometryTopic>
      <robotBaseFrame>base_link</robotBaseFrame>

      <updateRate>50</updateRate>
    </plugin>

  </model>
</sdf>
